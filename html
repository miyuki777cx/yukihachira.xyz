<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>💖 Welcome 💖</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    overflow:hidden;
    background:linear-gradient(135deg,#ffd6ea,#ffffff,#ffe8f5);
}

/* ================= INTRO ================= */

#intro{
    position:fixed;
    inset:0;
    background:linear-gradient(135deg,#ffd6ea,#ffffff,#ffe8f5);
    display:flex;
    justify-content:center;
    align-items:center;
    z-index:9999;
    transition:1s;
}

.intro-box{
    text-align:center;
    animation:zoomIn 1.2s ease;
    z-index:2;
}

.logo{
    font-size:100px;
    animation:heartbeat 1.5s infinite;
}

.intro-title{
    font-size:72px;
    font-weight:bold;
    color:#ff4f9d;
    letter-spacing:8px;
    text-shadow:0 0 25px rgba(255,255,255,.8);
}

.intro-sub{
    font-size:24px;
    color:#ff7eb6;
    margin-top:10px;
}

.loading{
    display:flex;
    justify-content:center;
    gap:10px;
    margin-top:30px;
}

.loading span{
    width:12px;
    height:12px;
    border-radius:50%;
    background:#ff69b4;
    animation:bounce 1s infinite;
}

.loading span:nth-child(2){
    animation-delay:.2s;
}

.loading span:nth-child(3){
    animation-delay:.4s;
}

.sparkle{
    position:absolute;
    font-size:24px;
    opacity:.5;
    animation:floatSpark linear infinite;
}

/* ================= MAIN ================= */

#main{
    display:none;
    width:100%;
    height:100vh;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    text-align:center;
    position:relative;
}

.main-title{
    font-size:60px;
    font-weight:bold;
    color:#ff4f9d;
    margin-bottom:20px;
    text-shadow:0 0 15px white;
}

.gif-box{
    width:320px;
    border-radius:25px;
    overflow:hidden;
    box-shadow:0 0 30px rgba(255,105,180,.35);
}

.bottom-text{
    margin-top:25px;
    font-size:34px;
    font-weight:bold;
    color:#ff69b4;
}

.heart{
    position:absolute;
    pointer-events:none;
    animation:floatHeart linear infinite;
}

/* ================= ANIMATION ================= */

@keyframes zoomIn{
    from{
        opacity:0;
        transform:scale(.7);
    }
    to{
        opacity:1;
        transform:scale(1);
    }
}

@keyframes heartbeat{
    0%,100%{
        transform:scale(1);
    }
    50%{
        transform:scale(1.15);
    }
}

@keyframes bounce{
    0%,100%{
        transform:translateY(0);
    }
    50%{
        transform:translateY(-10px);
    }
}

@keyframes floatSpark{
    from{
        transform:translateY(110vh) rotate(0deg);
    }
    to{
        transform:translateY(-120vh) rotate(360deg);
    }
}

@keyframes floatHeart{
    0%{
        transform:translateY(110vh);
        opacity:0;
    }

    20%{
        opacity:1;
    }

    100%{
        transform:translateY(-120vh);
        opacity:0;
    }
}
</style>
</head>
<body>

<!-- ================= INTRO ================= -->

<div id="intro">

    <div class="intro-box">

        <div class="logo">💖</div>

        <div class="intro-title">
            WELCOME
        </div>

        <div class="intro-sub">
            ยินดีต้อนรับเข้าสู่เว็บไซต์
        </div>

        <div class="loading">
            <span></span>
            <span></span>
            <span></span>
        </div>

    </div>

</div>

<!-- ================= MAIN ================= -->

<div id="main">

    <div class="main-title">
        ยินดีต้อนรับ 💕
    </div>

    <div class="gif-box">

        <div class="tenor-gif-embed"
            data-postid="17335643218552398559"
            data-share-method="host"
            data-aspect-ratio="1.1267"
            data-width="100%">
            <a href="https://tenor.com/view/cute-blinking-blinking-eyes-eyes-blinking-cute-face-gif-17335643218552398559">
                Cute Blinking GIF
            </a>
        </div>

    </div>

    <div class="bottom-text">
        คนส่องน่ารักจัง 🩷
    </div>

</div>

<script async src="https://tenor.com/embed.js"></script>

<script>

/* ---------- Intro Sparkles ---------- */

for(let i=0;i<30;i++){

    const s=document.createElement("div");

    s.className="sparkle";

    s.innerHTML=Math.random()>0.5?"✨":"🌸";

    s.style.left=Math.random()*100+"vw";

    s.style.fontSize=(20+Math.random()*25)+"px";

    s.style.animationDuration=(8+Math.random()*12)+"s";

    document.getElementById("intro").appendChild(s);
}

/* ---------- Change Page ---------- */

setTimeout(()=>{

    const intro=document.getElementById("intro");

    intro.style.opacity="0";

    setTimeout(()=>{

        intro.style.display="none";

        document.getElementById("main").style.display="flex";

    },1000);

},4500);

/* ---------- Floating Hearts ---------- */

function createHeart(){

    const heart=document.createElement("div");

    heart.className="heart";

    const icons=["💖","💕","🩷","🤍"];

    heart.innerHTML=icons[Math.floor(Math.random()*icons.length)];

    heart.style.left=Math.random()*100+"vw";

    heart.style.fontSize=(18+Math.random()*25)+"px";

    heart.style.animationDuration=(5+Math.random()*5)+"s";

    document.body.appendChild(heart);

    setTimeout(()=>{
        heart.remove();
    },10000);
}

setInterval(createHeart,350);

</script>

</body>
</html>
